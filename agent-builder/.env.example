# LiteLLM gateway (completions)
LITELLM_BASE_URL=https://api.example.com/v1
LITELLM_API_KEY=your-api-key-here
LITELLM_MODEL=gpt-5

# Databricks — for --fetch-describe (optional if you paste DESCRIBE manually)
DATABRICKS_HOST=https://adb-xxxx.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxx
# DATABRICKS_TOKEN=dapi...
TARGET_CATALOG=your_catalog

# Data Manager repo root (for --validate and default output path)
# Leave unset when agent-builder lives inside the data-editor repo
DATA_EDITOR_ROOT=../
